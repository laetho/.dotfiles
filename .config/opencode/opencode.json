{
  "$schema": "https://opencode.ai/config.json",
  "share": "disabled",
  "compaction": {
    "auto": true,
    "prune": true,
    "reserved": 32000
  },
  "provider": {
    "llama.cpp": {
      "npm": "@ai-sdk/openai-compatible",
      "options": {
        "baseURL": "http://localhost:8080/v1"
      },
      "models": {
        "unsloth/Qwen3.5-35B-A3B-GGUF:UD-Q4_K_XL": {
          "modalities": {
            "input": ["text", "image"],
            "output": ["text"]
          }
        }
      }
    },
    "dramallama": {
      "npm": "@ai-sdk/openai-compatible",
      "options": {
        "baseURL": "https://lame.ai.mattilsynet.io/v1",
        "apiKey": "key1"
      },
      "models": {
        "drama/code": {},
        "drama/code-thinking": {
          "modalities": {
            "input": ["text", "image"],
            "output": ["text"]
          }
        }
      }
    }
  },
  "model": "dramallama/drama/code",
  "plugin": ["./plugins/index.mjs"]
}
