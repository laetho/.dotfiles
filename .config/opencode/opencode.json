{
  "$schema": "https://opencode.ai/config.json",
  "share": "disabled",
  "compaction": {
    "auto": true,
    "prune": true,
    "reserved": 32000
  },
  "provider": {
    "llama.cpp": {
      "npm": "@ai-sdk/openai-compatible",
      "options": {
        "baseURL": "http://localhost:8080/v1"
      },
      "models": {
        "unsloth/Qwen3.5-35B-A3B-GGUF:UD-Q4_K_XL": {
          "modalities": {
            "input": ["text", "image"],
            "output": ["text"]
          }
        }
      }
    },
    "dramallama": {
      "npm": "@ai-sdk/openai-compatible",
      "options": {
        "baseURL": "https://lame.ai.mattilsynet.io/v1"
      },
      "models": {
        "drama/code": {},
        "drama/code-thinking": {
          "modalities": {
            "input": ["text", "image"],
            "output": ["text"]
          }
        }
      }
    }
  },
  "permission": {
    "read": {
      "**/.envrc": "deny",
      "**/.env": "deny",
      "**/.env.*": "deny",
      "**/*.env": "deny",
      "**/*.pem": "deny",
      "**/*.key": "deny",
      "**/*.p12": "deny",
      "**/*.pfx": "deny",
      "**/*.crt": "deny",
      "**/*.cer": "deny",
      "**/.ssh/**": "deny",
      "**/secrets/**": "deny",
      "**/.git-credentials": "deny",
      "**/.npmrc": "deny",
      "**/.docker/config.json": "deny",
      "**/*credentials*": "deny",
      "**/*password*": "deny",
      "**/*secret*": "deny"
    }
  },
  "model": "dramallama/drama/code-thinking",
  "plugin": ["./plugins/index.mjs"]
}
