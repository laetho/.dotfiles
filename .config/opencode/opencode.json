{
  "$schema": "https://opencode.ai/config.json",
  "share": "disabled",
  "compaction": {
    "auto": true,
    "prune": true,
    "reserved": 32000
  },
  "provider": {
    "llama.cpp": {
      "npm": "@ai-sdk/openai-compatible",
      "options": {
        "baseURL": "http://localhost:8888/v1"
      },
      "models": {
        "unsloth/Qwen3.6-35B-A3B": {
          "modalities": {
            "input": ["text", "image"],
            "output": ["text"]
          }
        },
        "unsloth/Qwen3.5-35B-A3B-GGUF:UD-Q4_K_XL": {
          "modalities": {
            "input": ["text", "image"],
            "output": ["text"]
          }
        }
      }
    },
    "dramallama": {
      "npm": "@ai-sdk/openai-compatible",
      "options": {
        "baseURL": "https://aiapi.mattilsynet.no/v1"
      },
      "models": {
        "code": {
          "id": "drama/code-thinking",
          "variants": {
            "instruct-general": {
                "temperature": 0.7,
                "top_p": 0.8,
                "top_k": 20,
                "min_p": 0.0,
                "presence_penalty": 1.5,
                "repetition_penalty": 1.0
            },
            "instruct-reasoning": {
                "temperature": 1.0,
                "top_p": 1.0,
                "top_k": 40,
                "min_p": 0.0,
                "presence_penalty": 2.0,
                "repetition_penalty": 1.0
            }
          },
          "tool_call": true,
          "limit": {
            "context": 128000,
            "output": 8000
          },
          "modalities": {
            "input": ["text"],
            "output": ["text"]
          }
        },
        "thinking": {
          "id": "drama/code-thinking",
          "options": {
            "chat_template_kwargs": {
              "enable_thinking": true
            }
          },
          "variants": {
            "precise-coding": {
                "temperature": 0.6,
                "top_p": 0.95,
                "top_k": 20,
                "min_p": 0.0,
                "presence_penalty": 0.0,
                "repetition_penalty": 1.0
            },
            "general-tasks": {
                "temperature": 1.0,
                "top_p": 0.95,
                "top_k": 20,
                "min_p": 0.0,
                "presence_penalty": 1.5,
                "repetition_penalty": 1.0
            }
          },
          "tool_call": true,
          "limit": {
            "context": 128000,
            "output": 8000
          },
          "modalities": {
            "input": ["text"],
            "output": ["text"]
          }
        }
      }
    }
  },
  "permission": {
    "*": "ask",
    "read": {
      "*": "allow",
      "**/.envrc": "deny",
      "**/.env": "deny",
      "**/.env.*": "deny",
      "**/*.env": "deny",
      "**/*.pem": "deny",
      "**/*.key": "deny",
      "**/*.p12": "deny",
      "**/*.pfx": "deny",
      "**/*.crt": "deny",
      "**/*.cer": "deny",
      "**/.ssh/**": "deny",
      "**/secrets/**": "deny",
      "**/.git-credentials": "deny",
      "**/.npmrc": "deny",
      "**/.docker/config.json": "deny",
      "**/*credentials*": "deny",
      "**/*password*": "deny",
      "**/*secret*": "deny",
      "**/id_rsa*": "deny",
      "**/id_ed25519*": "deny",
      "**/.aws/**": "deny",
      "**/*.tfvars": "deny"
    },
    "glob": { "*": "allow" },
    "grep": { "*": "allow" },
    "list": { "*": "allow" },
    "codesearch": "allow",
    "lsp": { "*": "allow" },
    "edit": { "*": "deny" },
    "write": { "*": "deny" },
    "bash": { "*": "deny" },
    "task": { "*": "deny" },
    "skill": { "*": "ask" },
    "webfetch": "allow",
    "websearch": "allow",
    "question": "allow",
    "todowrite": "deny",
    "external_directory": "deny",
    "doom_loop": "deny"
  },
  "default_agent": "planner",
  "agent": {
    "plan": {
      "disable": true
    },
    "build": {
      "disable": true
    }
  },
  "model": "dramallama/thinking",
  "plugin": ["./plugins/index.mjs"]
}
